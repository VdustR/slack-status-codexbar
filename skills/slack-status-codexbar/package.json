{
  "name": "slack-status-codexbar",
  "private": true,
  "version": "0.1.0",
  "description": "Slack status integration powered by CodexBar usage providers.",
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "esbuild src/hook.ts --bundle --platform=node --format=esm --outfile=dist/hook.mjs --target=node22",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
